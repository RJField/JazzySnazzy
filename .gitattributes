# Normalize line endings on checkin; check out LF.
* text=auto eol=lf

# ---- Godot text formats (explicit, so nothing gets guessed wrong) ----
*.gd        text eol=lf
*.gdshader  text eol=lf
*.tscn      text eol=lf
*.tres      text eol=lf
*.godot     text eol=lf
*.import    text eol=lf
*.uid       text eol=lf
*.cfg       text eol=lf

# ---- Binary: exclude from diff/merge, no EOL munging ----
*.png       binary
*.jpg       binary
*.webp      binary
*.svg       text eol=lf

# ---- Git LFS ----
*.ogg       filter=lfs diff=lfs merge=lfs -text
*.wav       filter=lfs diff=lfs merge=lfs -text
*.mp3       filter=lfs diff=lfs merge=lfs -text
*.aseprite  filter=lfs diff=lfs merge=lfs -text
*.ase       filter=lfs diff=lfs merge=lfs -text
*.kra       filter=lfs diff=lfs merge=lfs -text
*.psd       filter=lfs diff=lfs merge=lfs -text
*.blend     filter=lfs diff=lfs merge=lfs -text
*.ttf       filter=lfs diff=lfs merge=lfs -text
*.otf       filter=lfs diff=lfs merge=lfs -text